{
  "version": 2,
  "public": true,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/css/(.*)", "destination": "/src/css/$1" },
    { "source": "/js/(.*)", "destination": "/src/js/$1" },
    { "source": "/assets/(.*)", "destination": "/src/assets/$1" },
    { "source": "/(.*)", "destination": "/src/pages/index.html" }
  ]
}